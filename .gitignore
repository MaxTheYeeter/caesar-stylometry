# ============================================================================
# .gitignore — Caesar Stylometry project
# ============================================================================
# Excludes virtual environments, bytecode, raw/derived data, generated outputs,
# OS and editor junk, and R session detritus.
# Directory skeletons are preserved because .gitkeep files are NOT ignored.

# --- Python virtual environment ---
venv/

# --- Python bytecode & packaging detritus ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# --- Source data (large TEI XML files — download separately) ---
# Ignore everything in data/raw/ EXCEPT .gitkeep
data/raw/*
!data/raw/.gitkeep
!data/raw/perseus/
data/raw/perseus/*
!data/raw/perseus/.gitkeep
!data/raw/perseus/caes_bg_lat.xml
!data/raw/perseus/caes.bc_lat.xml


# --- Derived CSV corpora (generated by the parsing pipeline) ---
data/corpus/*.csv

# --- Intermediate processing artifacts ---
data/processed/*
!data/processed/.gitkeep
!data/processed/chapters/
data/processed/chapters/*
!data/processed/chapters/.gitkeep

# --- Generated outputs (tables, matrices, results) ---
outputs/*
!outputs/.gitkeep

# --- Generated figures (plots) ---
figures/*
!figures/.gitkeep

# --- Logs ---
logs/*
!logs/.gitkeep

# --- Plain-text corpus exports for stylo (generated, not committed) ---
data/stylo_corpus_tokens/*
!data/stylo_corpus_tokens/.gitkeep
data/stylo_corpus_lemmas/*
!data/stylo_corpus_lemmas/.gitkeep

# --- macOS junk ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# --- R junk ---
.Rhistory
.RData
.Rproj.user/
*.Rproj

# --- Editor / IDE junk ---
.vscode/
.idea/
*.swp
*.swo
*~

