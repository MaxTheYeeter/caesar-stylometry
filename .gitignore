# ============================================================================
# .gitignore — Caesar Stylometry project
# ============================================================================
# Excludes virtual environments, bytecode, model cache, OS/editor junk, and
# R session detritus.
#
# ALL analysis outputs, figures, CSV corpora, feature matrices, and distance
# matrices ARE committed to the repository so that results are viewable
# directly on GitHub without running the pipeline.

# --- Python virtual environment ---
venv/

# --- Python bytecode & packaging detritus ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# --- Latin BERT model cache (downloaded separately) ---
models/
.cache/huggingface/

# --- macOS junk ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# --- R junk ---
.Rhistory
.RData
.Rproj.user/
*.Rproj

# --- Editor / IDE junk ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- R/stylo auto-generated output (written to CWD unless redirected) ---
stylo_config.txt
table_with_frequencies.txt
wordlist.txt
*_EDGES.csv

# --- R/stylo auto-generated output (written to CWD unless redirected) ---
stylo_config.txt
table_with_frequencies.txt
wordlist.txt
*_EDGES.csv
